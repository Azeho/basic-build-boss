# Google reCAPTCHA Configuration
# Get your keys at https://www.google.com/recaptcha/admin

# Public site key (used in frontend)
VITE_RECAPTCHA_SITE_KEY=your_site_key_here

# Secret key (used in backend/serverless functions - NEVER expose to frontend)
RECAPTCHA_SECRET_KEY=your_secret_key_here

# SendGrid Email Configuration
# Get your API key at https://app.sendgrid.com/settings/api_keys
# Free tier: 100 emails/day

# SendGrid API Key (used in serverless functions)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Verified sender email (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=noreply@sungur-electronics.com
