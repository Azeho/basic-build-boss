# Environment Variables
# IMPORTANT: Create a .env file (copy this file) and add your actual keys
# The .env file should NOT be committed to git (it's in .gitignore)

# Google reCAPTCHA v2 Keys (REQUIRED for contact form reCAPTCHA to show)
# Get your keys from: https://www.google.com/recaptcha/admin
# Without these keys, the reCAPTCHA checkbox will NOT appear in the contact form

# Site Key (used in the frontend - required for reCAPTCHA to display)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Secret Key (used in contact.php backend - required for verification)
# This should also be set as an environment variable on your server
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# IMPORTANT FOR BUILDS:
# Before running 'npm run build', make sure you have created a .env file
# with your actual reCAPTCHA keys. Otherwise, the reCAPTCHA checkbox will
# not be included in the production build.
